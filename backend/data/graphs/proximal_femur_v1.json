{
  "id": "prox_femur_v1",
  "name": "ППОБК: выбор тактики лечения",
  "version": "1.0.0",
  "startNodeId": "q_age",
  "nodes": [
    {
      "id": "q_age",
      "type": "question",
      "label": "Возраст пациента (лет)?",
      "questionKind": "number",
      "key": "age",
      "unit": "лет"
    },
    {
      "id": "q_fracture_group",
      "type": "question",
      "label": "Локализация/группа перелома?",
      "questionKind": "select",
      "key": "fractureGroup",
      "options": [
        { "value": "head", "label": "Головка бедренной кости (Pipkin)" },
        { "value": "neck", "label": "Шейка бедренной кости (Garden)" },
        { "value": "it", "label": "Чрезвертельный (AO 31A)" },
        { "value": "st", "label": "Подвертельный/31A3 (AO 32 / AO 31A3)" }
      ]
    },

    {
      "id": "q_pipkin",
      "type": "question",
      "label": "Класс Pipkin?",
      "questionKind": "select",
      "key": "pipkin",
      "options": [
        { "value": "I", "label": "Pipkin I" },
        { "value": "II", "label": "Pipkin II" },
        { "value": "III", "label": "Pipkin III" },
        { "value": "IV", "label": "Pipkin IV" }
      ]
    },

    {
      "id": "q_garden",
      "type": "question",
      "label": "Класс Garden?",
      "questionKind": "select",
      "key": "garden",
      "options": [
        { "value": "I", "label": "Garden I" },
        { "value": "II", "label": "Garden II" },
        { "value": "III", "label": "Garden III" },
        { "value": "IV", "label": "Garden IV" }
      ]
    },

    {
      "id": "q_ao31",
      "type": "question",
      "label": "Класс AO/OTA 31A?",
      "questionKind": "select",
      "key": "ao31",
      "options": [
        { "value": "31A1.2", "label": "31A1.2 (стабильный)" },
        { "value": "31A1.3", "label": "31A1.3 (нестабильный)" },
        { "value": "31A2", "label": "31A2 (нестабильный)" },
        { "value": "31A3", "label": "31A3 (реверсивный/поперечный)" }
      ]
    },

    {
      "id": "q_cognition",
      "type": "question",
      "label": "Есть выраженные когнитивные нарушения/деменция?",
      "questionKind": "yesno",
      "key": "cognitiveImpairment"
    },

    {
      "id": "q_high_dislocation_risk",
      "type": "question",
      "label": "Высокий риск вывиха (ОНМК/нейромышечные/эпилепсия/деменция)?",
      "questionKind": "yesno",
      "key": "highDislocationRisk"
    },

    {
      "id": "cond_neck_stability",
      "type": "condition",
      "label": "Стабильность перелома шейки (Garden I–II = стабильный)",
      "expression": "(ctx.answers.garden === 'I' || ctx.answers.garden === 'II')"
    },

    {
      "id": "cond_age_ge_60",
      "type": "condition",
      "label": "Возраст ≥ 60?",
      "expression": "Number(ctx.answers.age) >= 60"
    },

    {
      "id": "cond_age_lt_60",
      "type": "condition",
      "label": "Возраст < 60?",
      "expression": "Number(ctx.answers.age) < 60"
    },

    {
      "id": "r_pipkin_lt60_I",
      "type": "recommendation",
      "label": "Pipkin I <60: удалить фрагмент",
      "recommendation": { "text": "Удаление фрагмента головки бедренной кости.", "sourceSection": "9.1" }
    },
    {
      "id": "r_pipkin_lt60_II",
      "type": "recommendation",
      "label": "Pipkin II <60: остеосинтез винтами",
      "recommendation": { "text": "Остеосинтез фрагментов головки канюлированными компрессирующими винтами (возможность субхондрального погружения).", "sourceSection": "9.1" }
    },
    {
      "id": "r_pipkin_lt60_III",
      "type": "recommendation",
      "label": "Pipkin III <60: первичное ТЭТС",
      "recommendation": { "text": "Первичное тотальное эндопротезирование тазобедренного сустава (ТЭТС).", "sourceSection": "9.1" }
    },

    {
      "id": "r_pipkin_ge60_I",
      "type": "recommendation",
      "label": "Pipkin I ≥60: удалить фрагмент",
      "recommendation": { "text": "Удаление фрагмента головки бедренной кости.", "sourceSection": "9.1" }
    },
    {
      "id": "r_pipkin_ge60_II_III",
      "type": "recommendation",
      "label": "Pipkin II–III ≥60: ТЭТС",
      "recommendation": { "text": "Тотальное эндопротезирование тазобедренного сустава (ТЭТС).", "sourceSection": "9.1" }
    },

    {
      "id": "r_garden_stable_any",
      "type": "recommendation",
      "label": "Garden I–II: остеосинтез",
      "recommendation": { "text": "Остеосинтез перелома шейки бедренной кости (предпочтительно телескопические винты с угловой стабильностью).", "levelOfEvidence": "A", "sourceSection": "9.2" }
    },

    {
      "id": "r_garden_unstable_lt60",
      "type": "recommendation",
      "label": "Garden III–IV <60: остеосинтез",
      "recommendation": { "text": "Остеосинтез (возможные конструкции: 3 параллельных винта / DHS / телескопические винты).", "sourceSection": "9.3" }
    },

    {
      "id": "r_garden_unstable_ge60_tha",
      "type": "recommendation",
      "label": "Garden III–IV ≥60: ТЭТС (активный, без когнитивн. нарушений)",
      "recommendation": { "text": "Тотальное эндопротезирование тазобедренного сустава при самостоятельной ходьбе и отсутствии выраженных когнитивных нарушений.", "levelOfEvidence": "A", "sourceSection": "9.3.1" }
    },
    {
      "id": "r_garden_unstable_ge60_hemi",
      "type": "recommendation",
      "label": "Garden III–IV ≥60: гемиэндопротезирование (когнитивн. нарушения/низкая активность)",
      "recommendation": { "text": "Гемиэндопротезирование при выраженных когнитивных нарушениях/низкой активности.", "levelOfEvidence": "A", "sourceSection": "9.3.1" }
    },
    {
      "id": "r_garden_unstable_ge60_dualmob",
      "type": "recommendation",
      "label": "Garden III–IV ≥60: ТЭТС с двойной мобильностью (высокий риск вывиха)",
      "recommendation": { "text": "ТЭТС с ацетабулярным компонентом двойной мобильности при высоком риске вывиха.", "sourceSection": "9.3.3" }
    },

    {
      "id": "r_31a1_2",
      "type": "recommendation",
      "label": "31A1.2: DHS",
      "recommendation": { "text": "Остеосинтез системой DHS при стабильных чрезвертельных переломах.", "levelOfEvidence": "A", "sourceSection": "9.4" }
    },
    {
      "id": "r_31a_unstable_lt60_static",
      "type": "recommendation",
      "label": "31A1.3/31A2 <60: ЦМФ статически",
      "recommendation": { "text": "Цефаломедуллярная фиксация (статический вариант). Нагрузка не ранее 8–10 недель.", "levelOfEvidence": "A", "sourceSection": "9.5" }
    },
    {
      "id": "r_31a_unstable_ge60_dynamic",
      "type": "recommendation",
      "label": "31A1.3/31A2 ≥60: ЦМФ динамически",
      "recommendation": { "text": "Цефаломедуллярная фиксация (динамический вариант) с ранней нагрузкой.", "levelOfEvidence": "A", "sourceSection": "9.5" }
    },

    {
      "id": "r_31a3_or_32",
      "type": "recommendation",
      "label": "31A3 / AO32: ЦМФ",
      "recommendation": { "text": "Цефаломедуллярный остеосинтез (предпочтительно длинная версия).", "levelOfEvidence": "A", "sourceSection": "9.6" }
    },

    {
      "id": "a_constraints_dhs",
      "type": "action",
      "label": "Тех. требования DHS",
      "action": { "code": "TECH_DHS", "text": "Контроль ЭОП 2 проекции; восстановить длину/ШДУ/антеверсию 10–15°; TAD < 25 мм; винт в зонах Кливленда 6/8/9." }
    },
    {
      "id": "a_constraints_cmf",
      "type": "action",
      "label": "Тех. требования ЦМФ",
      "action": { "code": "TECH_CMF", "text": "Точка входа — верхушка большого вертела; ЭОП 2 проекции; TAD < 25 мм; зоны Кливленда 6/8/9; при нестабильных предпочтительно длина ≥240 мм." }
    },
    {
      "id": "a_vte",
      "type": "action",
      "label": "ВТЭО профилактика",
      "action": { "code": "VTE", "text": "Тромбопрофилактика ВТЭО: начать сразу после травмы; механическая + медикаментозная; ранняя мобилизация." }
    }
  ],
  "edges": [
    { "source": "q_age", "target": "q_fracture_group", "condition": "default" },

    { "source": "q_fracture_group", "target": "q_pipkin", "condition": "expr:ctx.answers.fractureGroup==='head'" },
    { "source": "q_fracture_group", "target": "q_garden", "condition": "expr:ctx.answers.fractureGroup==='neck'" },
    { "source": "q_fracture_group", "target": "q_ao31", "condition": "expr:ctx.answers.fractureGroup==='it'" },
    { "source": "q_fracture_group", "target": "r_31a3_or_32", "condition": "expr:ctx.answers.fractureGroup==='st'" },

    { "source": "q_pipkin", "target": "cond_age_lt_60", "condition": "default" },
    { "source": "cond_age_lt_60", "target": "r_pipkin_lt60_I", "condition": "expr:ctx.lastCondition===true && ctx.answers.pipkin==='I'" },
    { "source": "cond_age_lt_60", "target": "r_pipkin_lt60_II", "condition": "expr:ctx.lastCondition===true && ctx.answers.pipkin==='II'" },
    { "source": "cond_age_lt_60", "target": "r_pipkin_lt60_III", "condition": "expr:ctx.lastCondition===true && ctx.answers.pipkin==='III'" },
    { "source": "cond_age_lt_60", "target": "cond_age_ge_60", "condition": "expr:ctx.lastCondition===false" },

    { "source": "cond_age_ge_60", "target": "r_pipkin_ge60_I", "condition": "expr:ctx.lastCondition===true && ctx.answers.pipkin==='I'" },
    { "source": "cond_age_ge_60", "target": "r_pipkin_ge60_II_III", "condition": "expr:ctx.lastCondition===true && (ctx.answers.pipkin==='II' || ctx.answers.pipkin==='III')" },

    { "source": "q_garden", "target": "cond_neck_stability", "condition": "default" },
    { "source": "cond_neck_stability", "target": "r_garden_stable_any", "condition": "expr:ctx.lastCondition===true" },
    { "source": "cond_neck_stability", "target": "cond_age_lt_60", "condition": "expr:ctx.lastCondition===false" },
    { "source": "cond_age_lt_60", "target": "r_garden_unstable_lt60", "condition": "expr:ctx.lastCondition===true" },
    { "source": "cond_age_lt_60", "target": "cond_age_ge_60", "condition": "expr:ctx.lastCondition===false" },

    { "source": "cond_age_ge_60", "target": "q_cognition", "condition": "expr:ctx.lastCondition===true" },
    { "source": "q_cognition", "target": "r_garden_unstable_ge60_hemi", "condition": "yes" },
    { "source": "q_cognition", "target": "q_high_dislocation_risk", "condition": "no" },
    { "source": "q_high_dislocation_risk", "target": "r_garden_unstable_ge60_dualmob", "condition": "yes" },
    { "source": "q_high_dislocation_risk", "target": "r_garden_unstable_ge60_tha", "condition": "no" },

    { "source": "q_ao31", "target": "r_31a1_2", "condition": "expr:ctx.answers.ao31==='31A1.2'" },
    { "source": "q_ao31", "target": "cond_age_lt_60", "condition": "expr:ctx.answers.ao31==='31A1.3' || ctx.answers.ao31==='31A2'" },
    { "source": "cond_age_lt_60", "target": "r_31a_unstable_lt60_static", "condition": "expr:ctx.lastCondition===true" },
    { "source": "cond_age_lt_60", "target": "r_31a_unstable_ge60_dynamic", "condition": "expr:ctx.lastCondition===false" },

    { "source": "r_31a1_2", "target": "a_constraints_dhs", "condition": "default" },
    { "source": "r_31a_unstable_lt60_static", "target": "a_constraints_cmf", "condition": "default" },
    { "source": "r_31a_unstable_ge60_dynamic", "target": "a_constraints_cmf", "condition": "default" },
    { "source": "r_31a3_or_32", "target": "a_constraints_cmf", "condition": "default" },

    { "source": "a_constraints_dhs", "target": "a_vte", "condition": "default" },
    { "source": "a_constraints_cmf", "target": "a_vte", "condition": "default" }
  ]
}